# Sovereign Platform — Local credentials
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must NEVER be committed.
#
# Usage: source .env   (or add to your shell profile)
#
# On the cluster, secrets live in Vault/Sealed Secrets.
# This file is only for bootstrap (before the cluster exists).

# ── GitHub ────────────────────────────────────────────────────────────────────
# Needed for: gh pr create (Proof of Work), ArgoCD repo access
# Get it: gh auth token   (after: gh auth login)
export GITHUB_TOKEN=""

# ── Hetzner Cloud ─────────────────────────────────────────────────────────────
# Needed for: bootstrap/providers/hetzner.sh (VPS provisioning)
# Get it: console.hetzner.cloud → <your-project> → Security → API Tokens → Generate
# Permissions: Read & Write
export HETZNER_TOKEN=""

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Needed for: bootstrap/frontdoor/cloudflare.sh (tunnel + DNS)
# Get it: dash.cloudflare.com → My Profile → API Tokens → Create Token (Custom)
# Permissions needed on the token:
#   Zone / DNS / Edit          (for wildcard A records)
#   Account / Cloudflare Tunnel / Edit   (for creating tunnels)
#   Account / Zero Trust / Edit          (for Access SSH policies)
# Zone Resources: Include / Specific zone / your-domain.com
export CLOUDFLARE_API_TOKEN=""

# Your Cloudflare Account ID
# Get it: dash.cloudflare.com → click your domain → right sidebar → Account ID
export CLOUDFLARE_ACCOUNT_ID=""

# Your Cloudflare Zone ID (the specific domain you're using)
# Get it: dash.cloudflare.com → click your domain → right sidebar → Zone ID
export CLOUDFLARE_ZONE_ID=""

# ── Domain ────────────────────────────────────────────────────────────────────
# The domain you own and have in Cloudflare (matches bootstrap/config.yaml)
export SOVEREIGN_DOMAIN="sovereign-autarky.dev"

# ── Optional providers (only needed if using those providers) ─────────────────
# DigitalOcean
export DIGITALOCEAN_TOKEN=""

# AWS (only if using aws-ec2 provider — not recommended, expensive for HA)
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
export AWS_DEFAULT_REGION="us-east-1"

# Sovereign Platform — Local credentials
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must NEVER be committed.
#
# Usage: source .env   (or add to your shell profile)
#
# On the cluster, secrets live in Vault/Sealed Secrets.
# This file is only for bootstrap (before the cluster exists).
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  TWO MODES — READ THIS FIRST                                                │
# │                                                                             │
# │  DEVELOPMENT / TESTING (kind cluster — local, free, no cloud account)       │
# │    → You only need GITHUB_TOKEN (Group 1).                                  │
# │    → Run ./kind/setup.sh to start a local cluster.                          │
# │    → No cloud credentials. No charges. Works entirely offline.              │
# │                                                                             │
# │  LIVE PROVISIONING (real VPS — only when you're ready for production)       │
# │    → You also need the variables in Groups 2 and 3.                         │
# │    → Triggered by: ./bootstrap/bootstrap.sh --confirm-charges               │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# For day-to-day development and testing, you only need GITHUB_TOKEN.
# Everything else is only needed when you're ready to provision real cloud
# infrastructure. Use ./kind/setup.sh for all local testing — it requires no
# cloud credentials.

# ══════════════════════════════════════════════════════════════════════════════
# GROUP 1 — ALWAYS NEEDED (for PR workflow)
# ══════════════════════════════════════════════════════════════════════════════

# Needed for: gh pr create, PR merge, ArgoCD repo access
# Get it: gh auth token   (after: gh auth login)
export GITHUB_TOKEN=""

# ══════════════════════════════════════════════════════════════════════════════
# GROUP 2 — NEEDED FOR kind TESTING (local, free, no cloud account required)
# ══════════════════════════════════════════════════════════════════════════════
#
# No credentials needed here. kind runs entirely on your local machine.
#
# Prerequisites:
#   brew install kind
#   Docker Desktop must be running
#
# Run ./kind/setup.sh to start a local cluster — no credentials needed.

# ══════════════════════════════════════════════════════════════════════════════
# GROUP 3 — ONLY NEEDED FOR LIVE PROVISIONING
#           (when running bootstrap.sh --confirm-charges)
# ══════════════════════════════════════════════════════════════════════════════

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Needed for: bootstrap/frontdoor/cloudflare.sh (tunnel + DNS)
# NOT needed until live VPS provisioning.
# Get it: dash.cloudflare.com → My Profile → API Tokens → Create Token (Custom)
# Permissions needed on the token:
#   Zone / DNS / Edit          (for wildcard A records)
#   Account / Cloudflare Tunnel / Edit   (for creating tunnels)
#   Account / Zero Trust / Edit          (for Access SSH policies)
# Zone Resources: Include / Specific zone / your-domain.com
export CLOUDFLARE_API_TOKEN=""

# Your Cloudflare Account ID
# Get it: dash.cloudflare.com → click your domain → right sidebar → Account ID
export CLOUDFLARE_ACCOUNT_ID=""

# Your Cloudflare Zone ID (the specific domain you're using)
# Get it: dash.cloudflare.com → click your domain → right sidebar → Zone ID
export CLOUDFLARE_ZONE_ID=""

# ── Domain ────────────────────────────────────────────────────────────────────
# The domain you own and have in Cloudflare (matches bootstrap/config.yaml)
# NOT needed until live VPS provisioning.
export SOVEREIGN_DOMAIN="sovereign-autarky.dev"

# ── Hetzner Cloud ─────────────────────────────────────────────────────────────
# Needed for: bootstrap/providers/hetzner.sh (VPS provisioning)
# NOT needed until live VPS provisioning.
# Get it: console.hetzner.cloud → <your-project> → Security → API Tokens → Generate
# Permissions: Read & Write
export HETZNER_TOKEN=""

# ── DigitalOcean (optional) ───────────────────────────────────────────────────
# NOT needed until you are using the DigitalOcean provider.
# Get it: cloud.digitalocean.com → API → Generate New Token
export DIGITALOCEAN_TOKEN=""

# ── AWS (optional) ────────────────────────────────────────────────────────────
# NOT needed until you are using the AWS EC2 provider.
# Note: not recommended for HA setups — can get expensive.
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
export AWS_DEFAULT_REGION="us-east-1"

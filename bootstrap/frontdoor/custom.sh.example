#!/usr/bin/env bash
# =============================================================================
# bootstrap/frontdoor/custom.sh.example
# Template for implementing a custom front door provider.
#
# USAGE
#   Copy this file to bootstrap/frontdoor/<yourname>.sh, implement each hook,
#   then set `frontDoor: <yourname>` in bootstrap/config.yaml.
#
# HOW IT WORKS
#   bootstrap.sh sources the chosen front door implementation and calls the
#   5 hook functions below in this order:
#
#     1. frontdoor_provision        (runs locally — create tunnel/service)
#     2. frontdoor_install_agent    (runs remotely via SSH — install daemon)
#     3. frontdoor_configure_dns    (runs locally — point DNS records)
#     4. frontdoor_connection_info  (runs locally — print access instructions)
#
#   firewall.sh reads the output of frontdoor_allowed_cidrs to determine which
#   CIDRs to whitelist before locking everything else down.
#
# ENVIRONMENT VARIABLES AVAILABLE IN EVERY HOOK
#   DOMAIN          — the primary domain from config.yaml  (e.g. example.com)
#   NODE_IPS        — space-separated list of all node IPs (e.g. "1.2.3.4 5.6.7.8")
#   SSH_KEY         — path to the SSH private key for remote access
#   CONFIG_FILE     — path to the full bootstrap/config.yaml
#
# REQUIREMENTS
#   - All hooks must be defined (even if they are no-ops).
#   - frontdoor_allowed_cidrs must print at least one CIDR (or "0.0.0.0/0" to
#     allow all, though that defeats the purpose of a front door).
#   - frontdoor_install_agent must be idempotent — safe to call more than once.
#   - frontdoor_provision must write any credentials/state to /tmp/frontdoor-*
#     so that subsequent hooks and cleanup routines can find them.
# =============================================================================

set -euo pipefail

# =============================================================================
# HOOK 1 — frontdoor_provision
#
# PURPOSE
#   Create the tunnel / VPN / reverse-proxy entry point on the service side.
#   This runs on the local machine (where bootstrap.sh is running), not on
#   the VPS.  Use provider APIs, CLI tools, or local config here.
#
# TYPICAL ACTIONS
#   - Create a tunnel or VPN gateway via your provider's API
#   - Generate a secret key / token for the VPS agent to authenticate with
#   - Write tunnel credentials to /tmp/frontdoor-credentials (chmod 600)
#   - Write an agent config file to /tmp/frontdoor-config (pushed in hook 2)
#
# OUTPUTS (write to /tmp/frontdoor-* files for use by later hooks)
#   /tmp/frontdoor-credentials  — secret the agent needs to auth (JSON or text)
#   /tmp/frontdoor-config       — agent configuration file
#   /tmp/frontdoor-endpoint     — public hostname/IP others connect through
#
# EXAMPLE (WireGuard-based front door)
#   - Generate a WireGuard keypair locally
#   - Create a WireGuard peer entry on a gateway VPS
#   - Write the peer config to /tmp/frontdoor-config
# =============================================================================
frontdoor_provision() {
  # TODO: implement tunnel/VPN/proxy creation here
  #
  # Example skeleton:
  #   local tunnel_name="sovereign-${DOMAIN//./-}"
  #   local secret; secret="$(openssl rand -hex 32)"
  #
  #   # Call your provider API …
  #   local tunnel_id; tunnel_id="$(your_api_create_tunnel "$tunnel_name" "$secret")"
  #
  #   # Write state for later hooks
  #   echo "$tunnel_id" > /tmp/frontdoor-tunnel-id
  #   printf '{"id":"%s","secret":"%s"}' "$tunnel_id" "$secret" \
  #       > /tmp/frontdoor-credentials
  #   chmod 600 /tmp/frontdoor-credentials
  #
  #   echo "frontdoor: tunnel created: $tunnel_id"

  echo "frontdoor_provision: NOT IMPLEMENTED — copy custom.sh.example and implement this hook" >&2
  exit 1
}

# =============================================================================
# HOOK 2 — frontdoor_install_agent
#
# PURPOSE
#   Install and start the tunnel/VPN agent daemon on every VPS node.
#   This function is called once per node; bootstrap.sh loops over $NODE_IPS.
#   Each call receives a single node IP as $1.
#
# ARGUMENTS
#   $1  — IP address of the target node
#
# TYPICAL ACTIONS
#   - SSH to the node and install the agent package (apt, curl | sh, etc.)
#   - Push /tmp/frontdoor-credentials and /tmp/frontdoor-config to the node
#   - Write the config to the standard location (e.g. /etc/myagent/config)
#   - Enable and start the systemd service
#   - Verify the agent is connected (optional but recommended)
#
# REQUIREMENTS
#   - Must be idempotent (safe to re-run if bootstrap is interrupted)
#   - Must not return until the agent is running and traffic can flow
#
# EXAMPLE (WireGuard-based front door)
#   - ssh to node, apt-get install -y wireguard
#   - push the peer config from /tmp/frontdoor-config to /etc/wireguard/wg0.conf
#   - systemctl enable --now wg-quick@wg0
# =============================================================================
frontdoor_install_agent() {
  local node_ip="${1:?frontdoor_install_agent: node_ip argument required}"
  : "${node_ip}"  # referenced in example below; used by callers

  # TODO: implement agent installation here
  #
  # Example skeleton:
  #   local SSH_OPTS=(-o StrictHostKeyChecking=no -o ConnectTimeout=30 -i "$SSH_KEY")
  #
  #   # Install agent binary
  #   ssh "${SSH_OPTS[@]}" "root@${node_ip}" 'apt-get install -y myagent'
  #
  #   # Push credentials
  #   scp "${SSH_OPTS[@]}" /tmp/frontdoor-credentials "root@${node_ip}:/etc/myagent/credentials"
  #   ssh "${SSH_OPTS[@]}" "root@${node_ip}" 'chmod 600 /etc/myagent/credentials'
  #
  #   # Push config and start service
  #   scp "${SSH_OPTS[@]}" /tmp/frontdoor-config "root@${node_ip}:/etc/myagent/config"
  #   ssh "${SSH_OPTS[@]}" "root@${node_ip}" 'systemctl enable --now myagent'

  echo "frontdoor_install_agent: NOT IMPLEMENTED — copy custom.sh.example and implement this hook" >&2
  exit 1
}

# =============================================================================
# HOOK 3 — frontdoor_allowed_cidrs
#
# PURPOSE
#   Print the CIDRs (one per line) that should be allowed through the firewall.
#   firewall.sh reads this output and creates UFW allow rules for each CIDR.
#   Everything else is blocked (UFW default-deny).
#
# WHEN TO PRINT NOTHING / A SMALL SET
#   If all traffic enters through an outbound-only tunnel (e.g. Cloudflare Tunnel,
#   WireGuard with full-tunnel routing), no inbound ports are needed at the OS
#   firewall level.  Print only monitoring/management CIDRs, or nothing at all.
#
# WHEN TO PRINT BROADER RANGES
#   If your front door is a reverse proxy that sends traffic from known IP ranges
#   (e.g. Cloudflare CDN IP ranges, Fastly subnets), print those ranges so UFW
#   allows them through while blocking everything else.
#
# OUTPUT FORMAT
#   One CIDR per line, e.g.:
#     192.0.2.0/24
#     198.51.100.0/24
#     2001:db8::/32
#
# EXAMPLE (WireGuard gateway)
#   Print the WireGuard gateway's public IP as /32 — only the gateway can reach
#   the nodes, everything else is dropped.
# =============================================================================
frontdoor_allowed_cidrs() {
  # TODO: implement CIDR output here
  #
  # Example — WireGuard gateway only:
  #   echo "203.0.113.1/32"
  #
  # Example — no inbound needed (outbound-only tunnel):
  #   : # print nothing — firewall blocks all inbound, tunnel is outbound-only
  #
  # Example — prompt user for their IP (useful for testing):
  #   if [[ -n "${FRONTDOOR_CALLER_IP:-}" ]]; then
  #     echo "${FRONTDOOR_CALLER_IP}/32"
  #   else
  #     printf 'Enter your public IP (or CIDR) to allow SSH access: ' >&2
  #     read -r caller_ip
  #     echo "${caller_ip}"
  #   fi

  echo "frontdoor_allowed_cidrs: NOT IMPLEMENTED — copy custom.sh.example and implement this hook" >&2
  exit 1
}

# =============================================================================
# HOOK 4 — frontdoor_configure_dns
#
# PURPOSE
#   Create or update DNS records so that traffic for *.<domain> is routed
#   through the front door (tunnel endpoint, reverse proxy, etc.).
#
# WHEN THIS RUNS
#   After frontdoor_provision and frontdoor_install_agent have completed.
#   The tunnel/VPN is up and the agent is running on all nodes.
#
# TYPICAL ACTIONS
#   - Create a wildcard CNAME: *.<domain> → <tunnel-endpoint>
#   - Or an A record: *.<domain> → <proxy-IP>
#   - Use your DNS provider's API or CLI (Cloudflare, Route53, etc.)
#   - Read /tmp/frontdoor-endpoint if the endpoint was written in hook 1
#
# REQUIREMENTS
#   - Must be idempotent (PUT/upsert, not POST/create-only)
#   - Should verify DNS record was created before returning
#
# EXAMPLE (WireGuard + Cloudflare DNS)
#   Use the Cloudflare API to create an A record pointing *.example.com at
#   the WireGuard gateway's public IP.
# =============================================================================
frontdoor_configure_dns() {
  # TODO: implement DNS configuration here
  #
  # Example skeleton:
  #   local endpoint; endpoint="$(cat /tmp/frontdoor-endpoint)"
  #   local CF_API_TOKEN; CF_API_TOKEN="$(yq '.cloudflare.apiToken' "$CONFIG_FILE")"
  #   local CF_ZONE_ID;   CF_ZONE_ID="$(yq '.cloudflare.zoneId' "$CONFIG_FILE")"
  #
  #   # Upsert wildcard CNAME
  #   curl -sS -X POST "https://api.cloudflare.com/client/v4/zones/${CF_ZONE_ID}/dns_records" \
  #     -H "Authorization: Bearer ${CF_API_TOKEN}" \
  #     -H "Content-Type: application/json" \
  #     -d "{\"type\":\"CNAME\",\"name\":\"*\",\"content\":\"${endpoint}\",\"proxied\":true}"

  echo "frontdoor_configure_dns: NOT IMPLEMENTED — copy custom.sh.example and implement this hook" >&2
  exit 1
}

# =============================================================================
# HOOK 5 — frontdoor_connection_info
#
# PURPOSE
#   Print human-readable instructions for how to connect to the cluster and
#   access services after bootstrap is complete.
#
# WHAT TO INCLUDE
#   - How to SSH to the nodes (through the tunnel, via a bastion, etc.)
#   - How to access the Kubernetes API (kubectl with the generated kubeconfig)
#   - The URLs for platform services (ArgoCD, Grafana, GitLab, etc.)
#   - Any additional tools or config needed (e.g. cloudflared client, WireGuard)
#
# STYLE
#   Keep it short and actionable.  The user has just run a long bootstrap script
#   and wants to know the 2-3 things to do next.
# =============================================================================
frontdoor_connection_info() {
  # TODO: implement connection info here
  #
  # Example:
  #   echo ""
  #   echo "=============================================="
  #   echo "  Bootstrap complete!"
  #   echo "=============================================="

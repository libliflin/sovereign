  #   echo ""
  #   echo "  Kubernetes:"
  #   echo "    export KUBECONFIG=~/.kube/sovereign-${DOMAIN}.yaml"
  #   echo "    kubectl get nodes"

  echo "frontdoor_connection_info: NOT IMPLEMENTED — copy custom.sh.example and implement this hook" >&2
  exit 1
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Strategic Theme",
  "type": "object",
  "required": ["id", "name", "vision", "successCriteria", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^T[0-9]+$" },
    "name": { "type": "string" },
    "vision": { "type": "string", "description": "One sentence: what does success look like?" },
    "successCriteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "status": { "type": "string", "enum": ["active", "complete", "paused"] },
    "relatedDocs": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}

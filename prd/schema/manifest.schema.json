{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/libliflin/sovereign/prd/schema/manifest.schema.json",
  "title": "Sovereign Sprint Manifest",
  "description": "Source of truth for the phase-based sprint system. Tracks all phases and points at the root.",
  "type": "object",
  "required": ["projectName", "description", "version", "activeSprint", "currentPhase", "phases"],
  "properties": {
    "projectName": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "activeSprint": {
      "type": "string",
      "description": "Relative path to the active sprint file (e.g. 'prd/phase-0-ceremonies.json')"
    },
    "currentPhase": {
      "type": "integer",
      "minimum": 0,
      "description": "Index of the currently active phase"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "file", "status"],
        "properties": {
          "id":          { "type": "integer", "minimum": 0 },
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "file":        { "type": "string", "description": "Relative path to the phase sprint file" },
          "status":      { "type": "string", "enum": ["pending", "active", "complete", "blocked"] },
          "dependsOn":   { "type": "array", "items": { "type": "integer" } },
          "startDate":   { "type": ["string", "null"] },
          "endDate":     { "type": ["string", "null"] },
          "capacity":    { "type": "integer", "minimum": 1, "description": "Max story points for this sprint" },
          "pointsTotal":     { "type": "integer" },
          "pointsCompleted": { "type": "integer" },
          "storiesTotal":    { "type": "integer" },
          "storiesAccepted": { "type": "integer" },
          "reviewPassRate":  { "type": ["number", "null"] },
          "retro":           { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "velocity": {
      "type": "array",
      "description": "One entry per completed sprint, written by retro ceremony",
      "items": {
        "type": "object",
        "properties": {
          "phase":           { "type": "integer" },
          "pointsCompleted": { "type": "integer" },
          "storiesAccepted": { "type": "integer" },
          "reviewPassRate":  { "type": "number" },
          "date":            { "type": "string" }
        }
      }
    },
    "sprintHistory": {
      "type": "array",
      "description": "Summary of completed sprints, appended by advance.sh",
      "items": {
        "type": "object",
        "properties": {
          "phase":           { "type": "integer" },
          "endDate":         { "type": "string" },
          "pointsCompleted": { "type": "integer" },
          "reviewPassRate":  { "type": "number" }
        }
      }
    }
  },
  "additionalProperties": false
}

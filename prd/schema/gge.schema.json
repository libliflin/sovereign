{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Golden Goose Eggs",
  "description": "The 3-5 outcomes that matter most right now. Defined by theme-review. Checked by orient before any other KPI.",
  "type": "object",
  "required": ["limit", "eggs"],
  "properties": {
    "_comment": { "type": "string" },
    "limit": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "const": 3 },
        "max": { "type": "integer", "const": 5 }
      }
    },
    "eggs": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "title", "themeId", "rationale", "indicator"],
        "properties": {
          "id": { "type": "string", "pattern": "^G[0-9]+$" },
          "title": { "type": "string", "minLength": 10 },
          "themeId": { "type": "string", "pattern": "^T[0-9]+$" },
          "rationale": { "type": "string", "description": "Why this is a golden egg right now (not forever)" },
          "indicator": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["file_exists", "files_exist", "story_complete", "gate_passing"]
              },
              "path": { "type": "string" },
              "paths": { "type": "array", "items": { "type": "string" } },
              "storyId": { "type": "string" },
              "command": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
